{
  "extends": "@electron-toolkit/tsconfig",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*.ts",
    "src/renderer/src/**/*.tsx",
    "src/renderer/src/**/*.js",
    "src/renderer/src/**/*.jsx",
    "src/renderer/src/**/*.vue",
    "src/preload/*.d.ts",
    "src/preload/db-types.ts",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@shared/*": ["src/shared/*"]
    }
  }
}
