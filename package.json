{
  "name": "piagent",
  "version": "0.0.5",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "test:main": "ELECTRON_RUN_AS_NODE=1 electron --experimental-transform-types --experimental-specifier-resolution=node --test tests/main/**/*.test.ts",
    "test:logic": "node --experimental-strip-types --test tests/renderer/chat/*.test.ts",
    "test:e2e": "pnpm run build && playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:headed": "pnpm run build && playwright test --config tests/e2e/playwright.config.ts --headed",
    "test:e2e:debug": "pnpm run build && PWDEBUG=1 playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:ui": "pnpm run build && playwright test --config tests/e2e/playwright.config.ts --ui",
    "check:packaged-deps": "node scripts/check-packaged-asar-deps.mjs",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "test": "electron-vite dev --mode test",
    "dev": "electron-vite dev",
    "build": "pnpm run typecheck && pnpm run build:computer-use-helper && electron-vite build",
    "build:computer-use-helper": "node scripts/build-computer-use-helper.mjs",
    "build:computer-use-echo-app": "node scripts/build-computer-use-echo-app.mjs",
    "postinstall": "electron-builder install-app-deps && node scripts/prepare-yl-animated-caret.mjs",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && npm_config_electron_mirror= NPM_CONFIG_ELECTRON_MIRROR= npm_package_config_electron_mirror= ELECTRON_MIRROR= electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "0.0.65",
    "@earendil-works/pi-agent-core": "0.80.10",
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@earendil-works/pi-tui": "0.80.10",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fastify/merge-json-schemas": "0.2.1",
    "@git-diff-view/vue": "^0.0.35",
    "@hono/node-server": "1.19.11",
    "@huggingface/transformers": "3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.48",
    "@tailwindcss/vite": "^4.3.0",
    "@vueuse/core": "^14.2.1",
    "agent-base": "7.1.4",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "base64-js": "1.5.1",
    "better-sqlite3": "^12.6.2",
    "bignumber.js": "9.3.1",
    "buffer-equal-constant-time": "1.0.1",
    "bufferutil": "^4.1.0",
    "content-type": "1.0.5",
    "cors": "2.8.6",
    "cross-spawn": "7.0.6",
    "data-uri-to-buffer": "4.0.1",
    "debug": "4.4.3",
    "dequal": "2.0.3",
    "diff": "8.0.4",
    "diff2html": "^3.4.52",
    "dompurify": "^3.3.2",
    "ecdsa-sig-formatter": "1.0.1",
    "electron-updater": "^6.3.9",
    "eventsource": "3.0.7",
    "eventsource-parser": "3.0.6",
    "express": "5.2.1",
    "express-rate-limit": "8.3.1",
    "extend": "3.0.2",
    "fastify": "^5.8.2",
    "fetch-blob": "3.2.0",
    "formdata-polyfill": "4.0.10",
    "gaxios": "7.1.4",
    "gcp-metadata": "8.1.2",
    "google-auth-library": "10.6.2",
    "google-logging-utils": "1.1.3",
    "has-flag": "4.0.0",
    "hono": "4.12.9",
    "https-proxy-agent": "7.0.6",
    "isexe": "3.1.5",
    "jose": "6.2.2",
    "json-bigint": "1.0.0",
    "json-schema-ref-resolver": "3.0.0",
    "json-schema-traverse": "0.4.1",
    "json-schema-typed": "8.0.2",
    "jwa": "2.0.1",
    "jws": "4.0.1",
    "kframe": "github:EnjoyWT/kframe",
    "lucide-vue-next": "^0.575.0",
    "marked": "^17.0.4",
    "ms": "2.1.3",
    "nanoid": "^5.1.7",
    "node-domexception": "1.0.0",
    "node-fetch": "3.3.2",
    "node-gyp-build": "4.8.4",
    "path-key": "3.1.1",
    "pkce-challenge": "5.0.1",
    "qrcode": "^1.5.4",
    "raw-body": "3.0.2",
    "safe-buffer": "5.2.1",
    "shebang-command": "2.0.0",
    "shebang-regex": "3.0.0",
    "supports-color": "7.2.0",
    "tailwindcss": "^4.3.0",
    "utf-8-validate": "^6.0.6",
    "web-streams-polyfill": "3.3.3",
    "which": "5.0.0",
    "yl-animated-caret": "github:EnjoyWT/YLAnimatedCaret",
    "zod": "4.3.6",
    "zod-to-json-schema": "3.25.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "6.0.0-beta.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "playwright": "1.59.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.16",
      "@earendil-works/pi-agent-core": "0.80.10",
      "@earendil-works/pi-ai": "0.80.10",
      "@earendil-works/pi-coding-agent": "0.80.10"
    },
    "onlyBuiltDependencies": [
      "@earendil-works/pi-coding-agent",
      "@earendil-works/pi-ai",
      "@earendil-works/pi-agent-core",
      "better-sqlite3",
      "electron",
      "esbuild",
      "kframe"
    ]
  }
}
